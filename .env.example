# 星仔高端定制 - 环境变量样例
# 复制为 .env 后按需修改

# ===== 后端 =====
STAR_HTTP_PORT=8181
STAR_MONGO_URI=mongodb://localhost:27017
STAR_DB_NAME=star
STAR_JWT_SECRET=star-dev-secret-please-change
STAR_CORS_ORIGINS=*

# 角色白名单 (手机号)
STAR_ADMIN_PHONE=13800138000
STAR_SALES_PHONES=13900000001,13900000002
STAR_SUPPLIER_PHONES=13700000001,13700000002
STAR_STATIC_CODE=1234

# ===== 前端 (Vite) =====
# dev server 代理目标
VITE_BASE=/
STAR_API_HOST=localhost
STAR_API_PORT=8181

# ===== ngrok (可选, 公网访问) =====
NGROK_AUTHTOKEN=
